select customer_id,customer_city
from custmore_data
where customer_city in('Nagpur','Pune','Satara');

select product_name,price
from product_data
where price>60000;

select customer_city,count(customer_id)
from custmore_data
group by customer_city;

select category,sum(price)
from product_data
group by category;


select sum(p.price*o.quantity) as total_sales
from product_data p inner join orders o
on p.product_id=o.product_id;

select category,sum(p.price*o.quantity) as total_sales
from product_data p inner join orders o
on p.product_id=o.product_id
group by category;

select c.customer_city,sum(p.price*o.quantity) as total_sales
from custmore_data c inner join orders o
on c.customer_id=o.customer_id
join product_data p
on p.product_id=o.product_id
group by c.customer_city
order by total_sales desc;

select p.product_name,sum(o.quantity) as total_quantity
from product_data p
join orders o
on p.product_id = o.product_id
group by p.product_name
order by total_quantity desc;
